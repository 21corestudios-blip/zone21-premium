# ARCANE environment template
# Copy to .env.local for local development.
# Configure the same keys in LWS/cPanel Node environment variables for staging and production.

# App
NEXT_PUBLIC_SITE_URL=https://zone-21.fr
APP_ENV=local
APP_SECRET=change-me
COMMERCE_ADMIN_REPLAY_ENABLED=false
COMMERCE_STAGING_PUBLIC_CHECK=false

# Storyblok editorial CMS
STORYBLOK_PUBLIC_TOKEN=
STORYBLOK_PREVIEW_TOKEN=
STORYBLOK_PREVIEW_SECRET=
STORYBLOK_API_BASE_URL=https://api.storyblok.com

# Stripe platform
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PLATFORM_FEE_BPS=1200

# Stripe connected accounts by brand
STRIPE_CONNECT_ACCOUNT_WEAR=
STRIPE_CONNECT_ACCOUNT_CORE=
STRIPE_CONNECT_ACCOUNT_PRODUCTION=
STRIPE_CONNECT_ACCOUNT_TALENTS=

# Printify backend-only
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
PRINTIFY_API_BASE_URL=https://api.printify.com/v1

# Gelato backend-only
GELATO_API_KEY=
GELATO_STORE_ID=
GELATO_API_BASE_URL=https://order.gelatoapis.com
GELATO_DEFAULT_FILE_URL=

# Database / persistence
DATABASE_URL=
COMMERCE_FILE_DB_PATH=.data/commerce-db.json
WEAR_ALLOW_ESTIMATED_QUOTES=false
COMMERCE_STAGING_SCENARIO_RUN=false
COMMERCE_STAGING_WEAR_PRODUCT_ID=classic-tee-01
COMMERCE_STAGING_WEAR_VARIANT_ID=M
COMMERCE_STAGING_SECOND_PRODUCT_ID=brand-signature-system
COMMERCE_STAGING_SECOND_VARIANT_ID=default
COMMERCE_STAGING_CUSTOMER_EMAIL=staging@zone21.test
COMMERCE_STAGING_COUNTRY=FR
COMMERCE_STAGING_POSTAL_CODE=75001
COMMERCE_STAGING_CITY=Paris
COMMERCE_STAGING_ADDRESS_LINE1=1 rue de test
COMMERCE_STAGING_EU_COUNTRY=FR
COMMERCE_STAGING_EU_POSTAL_CODE=75001
COMMERCE_STAGING_EU_CITY=Paris
COMMERCE_STAGING_WEAR_US_PRODUCT_ID=classic-tee-01
COMMERCE_STAGING_WEAR_US_VARIANT_ID=M
COMMERCE_STAGING_US_COUNTRY=US
COMMERCE_STAGING_US_POSTAL_CODE=10001
COMMERCE_STAGING_US_CITY=New York

# LWS / deployment
NODE_ENV=development
PORT=3000
