# ZONE 21 environment template
# Copy to .env.local for local development.
# Configure the same keys in LWS/cPanel Node environment variables for staging and production.

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_ENV=local
APP_SECRET=change-me

# Storyblok editorial CMS
STORYBLOK_PUBLIC_TOKEN=
STORYBLOK_PREVIEW_TOKEN=
STORYBLOK_PREVIEW_SECRET=
STORYBLOK_API_BASE_URL=https://api.storyblok.com

# Stripe platform
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PLATFORM_FEE_BPS=1200

# Stripe connected accounts by brand
STRIPE_CONNECT_ACCOUNT_WEAR=
STRIPE_CONNECT_ACCOUNT_CORE=
STRIPE_CONNECT_ACCOUNT_PRODUCTION=
STRIPE_CONNECT_ACCOUNT_TALENTS=

# Printify backend-only
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
PRINTIFY_API_BASE_URL=https://api.printify.com/v1

# Gelato backend-only
GELATO_API_KEY=
GELATO_STORE_ID=
GELATO_API_BASE_URL=https://api.gelato.com

# Database / persistence
DATABASE_URL=
ORDER_STORAGE_DRIVER=memory

# LWS / deployment
NODE_ENV=development
PORT=3000
